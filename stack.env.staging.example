# Copy to stack.env for the staging stack (docker-compose.staging.yml).
# Host port (SERVICE_PORT) is for curl from the server; containers talk on SERVER_PORT.

SERVICE_CONTAINER_NAME=mcp-api-staging
SERVICE_PORT=4006
SERVER_PORT=3006
TRANSPORT=http
LOG_LEVEL=info

# Use the staging CONTAINER name (unique across the host), never the bare
# service name "transaction-service-v2": both the prod and staging compose
# stacks use that service key, so on any shared network Docker DNS resolves
# it to BOTH environments and round-robins requests between them.
# Do not use localhost or the host-mapped port (1236) either.
TRANSACTION_SERVICE_URL=http://transaction-service-v2-staging:8080/api/v2
