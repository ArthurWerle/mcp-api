# Copy to stack.env for the staging stack (docker-compose.staging.yml).
# Host port (SERVICE_PORT) is for curl from the server; containers talk on SERVER_PORT.

SERVICE_CONTAINER_NAME=mcp-api-staging
SERVICE_PORT=4006
SERVER_PORT=3006
TRANSPORT=http
LOG_LEVEL=info

# Use the Docker service name on staging_bff_back-end (same network as transactions staging).
# Do not use localhost or the host-mapped port (1236).
TRANSACTION_SERVICE_URL=http://transaction-service-v2:8080/api/v2
